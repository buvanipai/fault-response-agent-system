@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row">
            <span style="color: var(--text-muted); font-size: 0.78rem; font-family: 'JetBrains Mono', monospace;">
                ● LIVE
            </span>
            <NavLink class="nav-link" href="https://github.com/buvanipai/fault-response-agent-system" target="_blank">
                <span class="nav-icon">↗</span>
                <span>GitHub</span>
            </NavLink>
        </div>

        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">✕</span>
</div>
